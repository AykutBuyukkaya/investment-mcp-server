# stdio is best for local MCP clients. Use streamable-http for HTTP development.
MCP_TRANSPORT=stdio

# Yahoo Finance chart API settings.
YF_BASE_URL=https://query2.finance.yahoo.com
YF_TIMEOUT_CONNECT_SECONDS=3.0
YF_TIMEOUT_READ_SECONDS=7.0
YF_TIMEOUT_TOTAL_SECONDS=10.0
YF_MAX_RETRIES=3
YF_RETRY_BACKOFF_BASE=0.25
YF_USER_AGENT=investment-mcp-server/0.1.0
YF_DEFAULT_INCLUDE_PREPOST=false

# Rate limiting (requests per second per upstream provider).
# Burst capacity is automatically set to 2x the RPS value.
YF_RATE_LIMIT_RPS=5.0
GOLD_RATE_LIMIT_RPS=2.0
FUND_RATE_LIMIT_RPS=2.0
PORTFOLIO_RATE_LIMIT_RPS=10.0
